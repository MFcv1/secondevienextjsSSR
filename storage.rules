rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      
      // BLINDAGE ADMINISTRATEUR (Standard & Robuste)
      // Seul l'admin identifié peut uploader. 
      // On bloque les fichiers trop gros (>10Mo), les non-images et les SVG executables.
      allow write: if request.auth != null
        && (
          request.auth.token.admin == true ||
          request.auth.token.superAdmin == true
        )
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp|gif|avif)');
    }
  }
}

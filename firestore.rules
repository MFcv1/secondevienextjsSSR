rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fonction Admin SECURISEE - Custom Claim Firebase Auth requis.
    function isArtisan() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Fonction Validation User (Basic)
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function ownerProfileCreateIsSafe() {
      return !request.resource.data.keys().hasAny(['role', 'securityData']);
    }

    function ownerProfileWriteIsSafe() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'securityData']);
    }

    function isPublicMetadataDoc(docId) {
      return docId in [
        'contact_info',
        'delivery',
        'gallery_app',
        'homepage_images',
        'payment_settings',
        'theme_settings'
      ];
    }

    function hasTrustedCheckoutAuth() {
      return request.auth != null && (
        request.auth.token.email_verified == true ||
        request.auth.token.firebase.sign_in_provider == 'google.com' ||
        request.auth.token.firebase.identities['google.com'] is list
      );
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isArtisan();
      allow create: if isOwner(userId) && ownerProfileCreateIsSafe();
      allow update: if isArtisan() || (isOwner(userId) && ownerProfileWriteIsSafe());
    }

    // Validation Helpers
    function isValidProduct() {
      let data = request.resource.data;
      return
        data.name is string && data.name.size() > 0 && data.name.size() < 140 &&
        data.description is string && data.description.size() < 10000 &&
        (!("currentPrice" in data) || (data.currentPrice is number && data.currentPrice >= 0)) &&
        (!("startingPrice" in data) || (data.startingPrice is number && data.startingPrice >= 0)) &&
        (data.images is list) &&
        (!("thumbnails" in data) || data.thumbnails is list);
    }

    // Collections produits (furniture, cutting_boards, etc.)
    match /artifacts/{appId}/public/data/{collectionName}/{itemId} {
      allow read: if isArtisan() || resource.data.status == 'published';
      allow create, update: if isArtisan() && isValidProduct();
      allow delete: if isArtisan();

    }

    match /artifacts/{appId}/public/meta {
      allow read: if true;
      allow write: if isArtisan();
    }

    // Newsletter Subscribers
    match /newsletter_subscribers/{docId} {
      allow create: if false; // Via Cloud Function uniquement
      allow read, update, delete: if isArtisan();
    }

    // Fonction Validation Cart
    function isValidCartItem() {
      let data = request.resource.data;
      return
        data.keys().size() < 10 &&
        (data.quantity is number && data.quantity > 0) &&
        (data.price is number && data.price >= 0);
    }

    // Panier utilisateur
    match /users/{userId}/cart/{cartItem} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId && (isValidCartItem() || request.method == 'delete');
    }

    // Wishlist utilisateur
    match /users/{userId}/wishlist/{wishlistItem} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Commandes
    match /orders/{orderId} {
      allow read, write: if isArtisan();
      allow read: if request.auth != null && (
        (
          hasTrustedCheckoutAuth() &&
          (
            request.auth.uid == resource.data.userId ||
            request.auth.token.email == resource.data.userEmail
          )
        ) ||
        (
          resource.data.checkoutAuthMethod == 'guest_email_otp' &&
          request.auth.uid == resource.data.userId
        )
      );
      allow create: if false; // Via Cloud Function uniquement
    }

    // System Metadata
    match /sys_metadata/{docId} {
      allow read: if isArtisan() || isPublicMetadataDoc(docId);
      allow write: if isArtisan();
    }

    // Rate Limiting (Backend-Only)
    match /sys_ratelimit/{docId} {
      allow read, write: if false;
    }

    // Idempotency Keys (Backend-Only)
    match /sys_idempotency/{docId} {
      allow read, write: if false;
    }

    // Analytics Sessions
    match /analytics_sessions/{docId} {
      allow read: if isArtisan();
      allow write: if false; // Cloud Functions only

      match /{subCollection}/{subDocId} {
        allow read: if isArtisan();
        allow write: if false;
      }
    }

    match /analytics_item_daily/{docId} {
      allow read: if isArtisan();
      allow write: if false;
    }

    match /analytics_page_daily/{docId} {
      allow read: if isArtisan();
      allow write: if false;
    }

    match /analytics_transition_daily/{docId} {
      allow read: if isArtisan();
      allow write: if false;
    }

    match /dashboard_stats/{docId} {
      allow read: if isArtisan();
      allow write: if false;
    }

    match /sales_stats_daily/{docId} {
      allow read: if isArtisan();
      allow write: if false;
    }

    match /inventory_stats/{docId} {
      allow read: if isArtisan();
      allow write: if false;
    }
  }
}
